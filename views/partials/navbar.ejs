<nav class="navbar">
  <a href="<%= user.role === 'admin' ? '/admin' : '/dashboard' %>" class="nav-brand">
    <img src="/images/sail-logo.jpg" alt="SAIL" class="nav-logo">
    <div>
      <span class="nav-title">Festival Advance</span>
      <span class="nav-sub">Steel Authority of India Limited</span>
    </div>
  </a>
  <div class="nav-links">
    <% if (user.role === 'admin') { %>
    <a href="/admin" class="nav-link">Policy Settings</a>
    <% } else { %>
    <a href="/dashboard" class="nav-link">Dashboard</a>
    <% } %>
    <% if (user.role === 'employee') { %>
    <a href="/apply" class="nav-link">Apply</a>
    <% } %>
  </div>
  <div class="nav-user">
    <div class="user-avatar"><%= user.name.charAt(0) %></div>
    <div class="user-info">
      <span class="user-name"><%= user.name %></span>
      <span class="user-dept"><%= user.dept %> · <%= user.staffNo %></span>
    </div>
    <a href="/logout" class="logout-btn" title="Sign out">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
    </a>
  </div>
</nav>
