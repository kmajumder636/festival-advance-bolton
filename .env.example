# Copy this file to ".env" and fill in real values.
# Never commit your real .env — it is excluded by .gitignore.

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development

# ─── Oracle Cloud SSO (Oracle IDCS / IAM Identity Domain) ───────────────────
# Leave blank to simply redirect users to https://cloud.oracle.com/sign-in.
# To enable full OIDC login, register an app in your Oracle Identity Domain.
ORACLE_IDCS_URL=
ORACLE_CLIENT_ID=
ORACLE_CLIENT_SECRET=
ORACLE_REDIRECT_URI=http://localhost:3000/sso/callback
ORACLE_SCOPE=openid profile email
